#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

current_branch=$(git branch --show-current)

case "$current_branch" in
master | main)
	printf >&2 "\nBLOCKED: refusing to commit on %s.\n\n" "$current_branch"
	printf >&2 "  %s is protected. All work lands via a pull request.\n\n" "$current_branch"
	printf >&2 "  Create a feature branch first (--no-track keeps its upstream off %s):\n\n" "$current_branch"
	printf >&2 "      git checkout -b <name> --no-track origin/%s\n\n" "$current_branch"
	exit 1
	;;
esac

yarn lint-staged

if ! command -v ggshield >/dev/null 2>&1; then
	printf >&2 "\nggshield is required for secret scanning. Rebuild the devcontainer or install ggshield locally.\n\n"
	exit 1
fi

run_ggshield() {
	if [ "${GITGUARDIAN_API_KEY+x}" = x ] && [ -z "${GITGUARDIAN_API_KEY}" ]; then
		env -u GITGUARDIAN_API_KEY ggshield "$@"
	else
		ggshield "$@"
	fi
}

if ! run_ggshield api-status >/dev/null 2>&1; then
	printf >&2 "\nggshield authentication is required for secret scanning.\n"
	printf >&2 "Authenticate using one of these methods:\n"
	printf >&2 "  1. Run: ggshield auth login\n"
	printf >&2 "  2. Export: GITGUARDIAN_API_KEY=<your-key>\n\n"
	exit 1
fi

run_ggshield secret scan pre-commit
