#!/bin/sh

protected_refs="refs/heads/master refs/heads/main"
zero_sha="0000000000000000000000000000000000000000"

stdin_data=$(cat)

blocked_ref=""
blocked_kind=""

while read -r local_ref local_sha remote_ref remote_sha; do
	[ -z "$remote_ref" ] && continue

	for protected in $protected_refs; do
		if [ "$remote_ref" = "$protected" ]; then
			blocked_ref="$remote_ref"

			if [ "$local_sha" = "$zero_sha" ]; then
				blocked_kind="delete"
			elif [ "$remote_sha" != "$zero_sha" ] &&
				! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
				blocked_kind="force"
			fi
		fi
	done
done <<EOF
$stdin_data
EOF

if [ -n "$blocked_ref" ]; then
	current_branch=$(git branch --show-current)

	printf >&2 "\n"
	printf >&2 "BLOCKED: refusing to push to %s.\n\n" "$blocked_ref"

	case "$blocked_kind" in
	delete) printf >&2 "  This push would DELETE the protected branch.\n\n" ;;
	force) printf >&2 "  This push would FORCE-rewrite the protected branch.\n\n" ;;
	esac

	printf >&2 "  %s is protected. All work lands via a pull request.\n\n" "$blocked_ref"
	printf >&2 "  A push reaches %s even from a feature branch when that branch's\n" "$blocked_ref"
	printf >&2 "  upstream points at it. Verify the destination with:\n\n"
	printf >&2 "      git rev-parse --abbrev-ref '@{push}'\n"
	printf >&2 "      git config --get branch.%s.merge\n\n" "$current_branch"
	printf >&2 "  Publish the branch to its own ref instead:\n\n"
	printf >&2 "      git push -u origin %s\n\n" "$current_branch"
	exit 1
fi

command -v git-lfs >/dev/null 2>&1 || {
	printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."
	exit 2
}

printf '%s\n' "$stdin_data" | git lfs pre-push "$@"
