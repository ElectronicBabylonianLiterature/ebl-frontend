{
  "lint-staged": {
    "src/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.tsx": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.md": [
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "scripts": {
    "start": "craco start",
    "start:fast": "FAST_DEV=true DISABLE_ESLINT_PLUGIN=true craco start",
    "build": "NODE_OPTIONS=--max_old_space_size=1536 craco build",
    "build:ci-stable": "GENERATE_SOURCEMAP=false DISABLE_ESLINT_PLUGIN=true NODE_OPTIONS=--max_old_space_size=1536 craco build",
    "test": "NODE_OPTIONS=--max_old_space_size=1536 craco test --runInBand",
    "test:fast": "NODE_OPTIONS=--max_old_space_size=1536 craco test --maxWorkers=1 --workerIdleMemoryLimit=512MB --bail --no-coverage --watch=false",
    "test:diag": "CI=true NODE_OPTIONS=--max_old_space_size=1536 craco test --runInBand --coverage --forceExit --detectOpenHandles --watch=false --logHeapUsage",
    "test:secrets": "bash scripts/test-secret-scanning.sh",
    "eject": "react-scripts eject",
    "lighthouse": "node scripts/lighthouse.js",
    "lint": "eslint 'src/**/*.{ts,tsx}' && stylelint 'src/**/*.{css,sass}'",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "name": "ebl-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "yarn": "^1.5.1",
    "node": "^20.0.0"
